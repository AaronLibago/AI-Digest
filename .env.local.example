# Firebase Configuration (get from Firebase Console > Project Settings > Your Apps)
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id_here
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id_here
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id_here

# n8n Webhook URL (server-side only, not exposed to browser)
# This is the production webhook URL from your n8n instance
# Format: https://your-n8n-domain.com/webhook/ai-digest-trigger
N8N_WEBHOOK_URL=https://your-n8n-instance.com/webhook/ai-digest-trigger
