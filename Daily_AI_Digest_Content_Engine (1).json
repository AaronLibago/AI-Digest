      "id": "c5a49dcf-6b74-4a51-a13d-53aac9a4c8f4",
      "name": "Extract Top 10 AI Developments",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1152,
        1600
      ],
      "credentials": {
        "openAiApi": {
          "id": "M5wvsYYjdFFr59Fc",
          "name": "AI Digest"
