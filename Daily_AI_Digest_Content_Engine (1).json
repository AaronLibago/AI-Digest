    {
      "parameters": {
        "jsCode": "let parsed;\nconst raw = $json.choices?.[0]?.message?.content || '';\n\nif (!raw || raw.trim() === '[]') {\n  throw new Error('OpenAI returned empty array. Email body is still empty — check Clean HTML to Text output has actual content.');\n}\n\nconst cleaned = raw.replace(/```json/gi, '').replace(/```/g, '').trim();\n\ntry {\n  parsed = JSON.parse(cleaned);\n} catch (e) {\n  throw new Error('JSON parse failed. OpenAI returned: ' + raw.substring(0, 400));\n}\n\nif (!Array.isArray(parsed)) {\n  if (parsed.developments) parsed = parsed.developments;\n  else if (parsed.items) parsed = parsed.items;\n  else throw new Error('Expected array, got: ' + typeof parsed);\n}\n\nreturn [{ json: { top10: parsed } }];"
      },
      "id": "1969ccf6-56b2-4630-99da-7b3c22440a68",
      "name": "Parse JSON",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1376,
        1600
      ]
    },
    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const top10 = $json.top10;\n\nconst body = {\n  model: 'gpt-4o',\n  temperature: 0.6,\n  max_tokens: 3000,\n  messages: [\n    {\n      role: 'system',\n      content: 'You are writing a strategic AI newsletter article for a sophisticated audience of business leaders, technologists, and investors.'\n    },\n    {\n      role: 'user',\n      content: `Using the ranked AI developments below, write a 900-1200 word Substack article analyzing the trajectory of AI.\\n\\nRequirements:\\n- Strategic, composed tone\\n- Focus on patterns and 2-5 year implications\\n- 3-5 section headers (use ## for headers)\\n- Close with a 'What to Watch Next' section\\n- Do not mechanically list items, weave them into narrative\\n- Start with a compelling hook\\n\\nIdeas:\\n${JSON.stringify(top10, null, 2)}\\n\\nReturn plain text only.`\n    }\n  ]\n};\n\nreturn { requestBody: JSON.stringify(body), top10 };"
      },
