    {
      "parameters": {
        "mode": "runOnceForEachItem",
        "jsCode": "const rawB64 = $json.raw || '';\n\nif (!rawB64) {\n  throw new Error('No raw field found. Check HTTP Request node output.');\n}\n\nconst rawEmail = Buffer.from(\n  rawB64.replace(/-/g, '+').replace(/_/g, '/'),\n  'base64'\n).toString('utf-8');\n\nconst bodyStart = rawEmail.indexOf('\\r\\n\\r\\n');\nconst fullBody = bodyStart > -1 ? rawEmail.substring(bodyStart + 4) : rawEmail;\n\nconst boundary = rawEmail.match(/boundary=\"([^\"]+)\"/)?.[1];\nlet extractedText = '';\n\nif (boundary) {\n  const parts = fullBody.split('--' + boundary);\n  for (const part of parts) {\n    const ph = part.indexOf('\\r\\n\\r\\n');\n    if (ph === -1) continue;\n    const headers = part.substring(0, ph).toLowerCase();\n    const body = part.substring(ph + 4);\n    if (headers.includes('text/plain') || headers.includes('text/html')) {\n      const qp = body.replace(/=\\r\\n/g, '').replace(/=([0-9A-Fa-f]{2})/g, (_, h) => String.fromCharCode(parseInt(h, 16)));\n      if (qp.length > extractedText.length) extractedText = qp;\n    }\n  }\n}\n\nextractedText = extractedText || fullBody;\n\nconst text = extractedText\n  .replace(/<[^>]+>/g, ' ')\n  .replace(/&nbsp;/g, ' ').replace(/&amp;/g, '&')\n  .replace(/&lt;/g, '<').replace(/&gt;/g, '>')\n  .replace(/&quot;/g, '\"').replace(/&#39;/g, \"'\")\n  .replace(/\\s\\s+/g, '\\n').trim();\n\nreturn {\n  subject: $json.Subject || 'No Subject',\n  sender: $json.From || '',\n  date: $json.internalDate || '',\n  clean_text: text\n};"
      },
      "id": "1d4b8f0f-e633-4fcf-9389-e9db81b82fc6",
      "name": "Clean HTML to Text",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        496,
        1600
      ]
    },
    {
      "parameters": {
        "jsCode": "let combined = '';\n\nfor (const item of items) {\n  const subject = item.json.subject || 'No Subject';\n  const date = item.json.date || item.json.internalDate || '';\n  const text = item.json.clean_text || '';\n\n  combined += `\\n\\n---\\n\\nSOURCE: ${subject}\\nDATE: ${date}\\n\\n`;\n  combined += text;\n}\n\nreturn [{\n  json: {\n    digest_text: combined.trim(),\n    email_count: items.length\n  }\n}];"
      },
      "id": "f1c7390b-714d-4dfc-beac-9d7b33f75785",
      "name": "Combine All Emails",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        704,
        1600
      ]
    },
    {
      "parameters": {
        "jsCode": "const digestText = items[0].json.digest_text || '';\nconst emailCount = items[0].json.email_count || 0;\n\nif (!digestText || digestText.length < 50) {\n  throw new Error(`Email body too short (${digestText.length} chars). Clean HTML to Text node is not extracting content. Check Gmail Get Message format is set to RAW.`);\n}\n\nconst body = {\n  model: 'gpt-4o',\n  temperature: 0.3,\n  max_tokens: 2000,\n  messages: [\n    {\n      role: 'system',\n      content: 'You are an expert AI analyst. Extract signal, not hype. Return valid JSON only. No markdown. No code fences. No preamble.'\n    },\n    {\n      role: 'user',\n      content: `From the content below, extract the 10 most important AI developments.\\nRank by long-term significance.\\nReturn a STRICT JSON array where each item has exactly these fields:\\n  rank (number),\\n  title (string),\\n  one_sentence_summary (string),\\n  why_it_matters (string),\\n  practical_implication (string),\\n  risk_or_opportunity (string)\\n\\nContent:\\n${digestText}\\n\\nReturn JSON array only. No markdown. No explanation.`\n    }\n  ]\n};\n\nreturn [{\n  json: {\n    requestBody: JSON.stringify(body),\n    email_count: emailCount\n  }\n}];"
      },
      "id": "4f14de42-b5b6-450c-b265-644d0d7eab9a",
