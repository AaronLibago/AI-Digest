      "name": "Gmail Search",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2.1,
      "position": [
        48,
        1600
      ],
      "webhookId": "5b747b90-d479-410b-b6c9-2950b5ccab02",
      "credentials": {
        "gmailOAuth2": {
          "id": "JIQyraRI17jI5aax",
          "name": "AI Digest"
        }
